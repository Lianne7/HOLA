@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Forgot Password – HOLA</title>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700;800&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
    <style>
            *, *::before, *::after {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
            }

            :root {
                --primary-green: #2ECC71;
                --dark-green: #27AE60;
                --accent-orange: #E67E22;
                --neutral-dark: #2C3E50;
                --cream: #FFF5E6;
                --shadow: rgba(0,0,0,0.1);
            }

            body {
                font-family: 'Outfit', sans-serif;
                background: linear-gradient(135deg, #FFF5E6 0%, #E8F5E9 100%);
                min-height: 100vh;
                display: flex;
                align-items: center;
                justify-content: center;
                padding: 1.5rem;
                position: relative;
                overflow: hidden;
            }

            /* Background decorations — same as your login page */
            .bg-decoration {
                position: fixed;
                z-index: 0;
                opacity: 0.08;
                pointer-events: none;
            }

            .leaf-1 {
                top: 8%;
                left: 4%;
                width: 120px;
                height: 120px;
                background: var(--primary-green);
                border-radius: 0 100% 0 100%;
                animation: float 6s ease-in-out infinite;
            }

            .leaf-2 {
                bottom: 12%;
                right: 6%;
                width: 160px;
                height: 160px;
                background: var(--accent-orange);
                border-radius: 100% 0 100% 0;
                animation: float 8s ease-in-out infinite reverse;
            }

            .circle-1 {
                top: 45%;
                right: -60px;
                width: 220px;
                height: 220px;
                background: #3498DB;
                border-radius: 50%;
                animation: pulse 4s ease-in-out infinite;
            }

            @@keyframes float {
                0%, 100% {
                    transform: translateY(0) rotate(0deg);
                }

                50% {
                    transform: translateY(-28px) rotate(10deg);
                }
            }

            @@keyframes pulse {
                0%, 100% {
                    transform: scale(1);
                    opacity: 0.08;
                }

                50% {
                    transform: scale(1.1);
                    opacity: 0.13;
                }
            }

            @@keyframes slideUp {
                from {
                    opacity: 0;
                    transform: translateY(30px);
                }

                to {
                    opacity: 1;
                    transform: translateY(0);
                }
            }

            @@keyframes fadeIn {
                from {
                    opacity: 0;
                }

                to {
                    opacity: 1;
                }
            }

            /* Card */
            .card {
                background: white;
                border-radius: 28px;
                padding: 3rem 2.5rem;
                width: 100%;
                max-width: 460px;
                box-shadow: 0 20px 60px rgba(0,0,0,0.12);
                position: relative;
                z-index: 1;
                animation: slideUp 0.5s ease-out;
                overflow: hidden;
            }

                .card::before {
                    content: '';
                    position: absolute;
                    top: 0;
                    left: 0;
                    right: 0;
                    height: 6px;
                    background: linear-gradient(90deg, var(--primary-green), #3498DB, var(--accent-orange));
                }

            /* Logo */
            .logo {
                display: flex;
                align-items: center;
                justify-content: center;
                gap: 10px;
                margin-bottom: 2rem;
                animation: slideUp 0.5s ease-out 0.1s backwards;
            }

            .logo-icon {
                width: 44px;
                height: 44px;
                background: linear-gradient(135deg, var(--primary-green), var(--dark-green));
                border-radius: 12px;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 1.3rem;
                transform: rotate(-10deg);
                box-shadow: 0 4px 14px rgba(46,204,113,0.3);
            }

            .logo-text {
                font-size: 1.8rem;
                font-weight: 800;
                color: var(--primary-green);
            }

            /* Icon circle */
            .icon-circle {
                width: 72px;
                height: 72px;
                border-radius: 50%;
                background: linear-gradient(135deg, #E8F5E9, #D5F5E3);
                border: 2px solid rgba(46,204,113,0.25);
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 2rem;
                margin: 0 auto 1.5rem;
                animation: slideUp 0.5s ease-out 0.15s backwards;
            }

            .card-title {
                font-size: 1.7rem;
                font-weight: 800;
                color: var(--neutral-dark);
                text-align: center;
                margin-bottom: 0.5rem;
                animation: slideUp 0.5s ease-out 0.2s backwards;
            }

            .card-subtitle {
                font-size: 0.9rem;
                color: #7f8c8d;
                text-align: center;
                line-height: 1.6;
                margin-bottom: 2rem;
                animation: slideUp 0.5s ease-out 0.25s backwards;
            }

            /* Form */
            .form-group {
                margin-bottom: 1.25rem;
                animation: slideUp 0.5s ease-out 0.3s backwards;
            }

            .form-label {
                display: block;
                font-size: 0.85rem;
                font-weight: 600;
                color: var(--neutral-dark);
                margin-bottom: 7px;
            }

            .input-wrap {
                position: relative;
            }

            .input-icon {
                position: absolute;
                left: 14px;
                top: 50%;
                transform: translateY(-50%);
                font-size: 1rem;
                color: #b2bec3;
                pointer-events: none;
            }

            .form-input {
                width: 100%;
                padding: 13px 14px 13px 42px;
                border: 2px solid #e8e8e8;
                border-radius: 12px;
                font-family: 'Outfit', sans-serif;
                font-size: 0.95rem;
                color: var(--neutral-dark);
                background: #fafafa;
                outline: none;
                transition: all 0.25s;
            }

                .form-input:focus {
                    border-color: var(--primary-green);
                    background: white;
                    box-shadow: 0 0 0 4px rgba(46,204,113,0.1);
                }

                .form-input::placeholder {
                    color: #b2bec3;
                }

            /* Submit button */
            .btn-submit {
                width: 100%;
                padding: 14px;
                border: none;
                border-radius: 12px;
                background: linear-gradient(135deg, var(--primary-green), var(--dark-green));
                color: white;
                font-family: 'Outfit', sans-serif;
                font-size: 1rem;
                font-weight: 700;
                cursor: pointer;
                box-shadow: 0 4px 15px rgba(46,204,113,0.35);
                transition: all 0.3s;
                margin-bottom: 1.25rem;
                animation: slideUp 0.5s ease-out 0.35s backwards;
                display: flex;
                align-items: center;
                justify-content: center;
                gap: 8px;
            }

                .btn-submit:hover {
                    transform: translateY(-2px);
                    box-shadow: 0 6px 22px rgba(46,204,113,0.45);
                }

                .btn-submit:active {
                    transform: translateY(0);
                }

            /* Success state */
            .success-box {
                display: none;
                background: linear-gradient(135deg, #E8F5E9, #D5F5E3);
                border: 1.5px solid rgba(46,204,113,0.4);
                border-radius: 14px;
                padding: 1.2rem 1.5rem;
                text-align: center;
                margin-bottom: 1.25rem;
                animation: fadeIn 0.4s ease;
            }

                .success-box.show {
                    display: block;
                }

                .success-box .success-icon {
                    font-size: 2rem;
                    margin-bottom: 6px;
                }

                .success-box p {
                    font-size: 0.88rem;
                    color: var(--dark-green);
                    font-weight: 500;
                    line-height: 1.6;
                }

            /* Validation error */
            .field-error {
                font-size: 0.78rem;
                color: #E74C3C;
                margin-top: 5px;
                display: none;
            }

                .field-error.show {
                    display: block;
                }

            /* Divider */
            .divider {
                display: flex;
                align-items: center;
                gap: 12px;
                margin-bottom: 1.25rem;
                animation: slideUp 0.5s ease-out 0.4s backwards;
            }

            .divider-line {
                flex: 1;
                height: 1px;
                background: #e8e8e8;
            }

            .divider-text {
                font-size: 0.78rem;
                color: #b2bec3;
                white-space: nowrap;
            }

            /* Back to login */
            .back-link {
                display: flex;
                align-items: center;
                justify-content: center;
                gap: 8px;
                text-decoration: none;
                color: var(--neutral-dark);
                font-size: 0.9rem;
                font-weight: 600;
                padding: 11px;
                border-radius: 12px;
                border: 2px solid #e8e8e8;
                transition: all 0.25s;
                animation: slideUp 0.5s ease-out 0.45s backwards;
            }

                .back-link:hover {
                    border-color: var(--primary-green);
                    color: var(--primary-green);
                    background: rgba(46,204,113,0.05);
                }

            /* Footer note */
            .footer-note {
                text-align: center;
                font-size: 0.78rem;
                color: #b2bec3;
                margin-top: 1.5rem;
                animation: slideUp 0.5s ease-out 0.5s backwards;
            }
    </style>
</head>
<body>

    <!-- Background decorations -->
    <div class="bg-decoration leaf-1"></div>
    <div class="bg-decoration leaf-2"></div>
    <div class="bg-decoration circle-1"></div>

    <div class="card">

        <!-- Logo -->
        <div class="logo">
            <div class="logo-icon">🌱</div>
            <div class="logo-text">HOLA</div>
        </div>

        <!-- Icon -->
        <div class="icon-circle">🔑</div>

        <div class="card-title">Forgot Password?</div>
        <div class="card-subtitle">
            No worries! Enter your email address and we'll<br>
            send you a link to reset your password.
        </div>

        <!-- Success message (shown after submit) -->
        <div class="success-box" id="successBox">
            <div class="success-icon">✅</div>
            <p>If that email is registered, a reset link has been sent.<br>Please check your inbox.</p>
        </div>

        <!-- Form -->
        <form id="forgotForm" method="post" asp-action="ForgotPassword" asp-controller="Account">
            <div class="form-group">
                <label class="form-label" for="email">Email Address</label>
                <div class="input-wrap">
                    <span class="input-icon">📧</span>
                    <input type="email"
                           id="email"
                           name="email"
                           class="form-input"
                           placeholder="you@example.com"
                           required
                           autocomplete="email" />
                </div>
                <div class="field-error" id="emailError">Please enter a valid email address.</div>
            </div>

            <button type="submit" class="btn-submit" id="submitBtn">
                <span id="btnText">🔗 Send Reset Link</span>
            </button>
        </form>

        <div class="divider">
            <div class="divider-line"></div>
            <div class="divider-text">remembered your password?</div>
            <div class="divider-line"></div>
        </div>

        <a asp-controller="Account" asp-action="Login" class="back-link">
            ← Back to Login
        </a>

        <div class="footer-note">
            🌿 HOLA · Home-based Online Learning Assistant
        </div>
    </div>

    <script>
            const form = document.getElementById('forgotForm');
            const emailInput = document.getElementById('email');
            const emailError = document.getElementById('emailError');
            const successBox = document.getElementById('successBox');
            const submitBtn = document.getElementById('submitBtn');
            const btnText = document.getElementById('btnText');

            form.addEventListener('submit', function (e) {
                e.preventDefault();

                const email = emailInput.value.trim();
                const valid = /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/.test(email);

                if (!valid) {
                    emailError.classList.add('show');
                    emailInput.style.borderColor = '#E74C3C';
                    return;
                }

                emailError.classList.remove('show');
                emailInput.style.borderColor = '';

                // Show loading state
                submitBtn.disabled = true;
                btnText.textContent = '⏳ Sending…';

                // Simulate sending (replace with real form.submit() if backend is ready)
                setTimeout(() => {
                    form.style.display = 'none';
                    successBox.classList.add('show');
                }, 1200);
            });

            emailInput.addEventListener('input', function () {
                emailError.classList.remove('show');
                emailInput.style.borderColor = '';
            });
    </script>
</body>
</html>
